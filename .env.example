# Template do .env do bot-planilha-sefaz. Copie para `.env` e preencha.
# O .env real é gitignored. No SRVRPS03, criar a partir deste arquivo.

# --- Portal SEFAZ-BA ---
SEFAZ_DEST=https://...        # URL da consulta como DESTINATÁRIO
SEFAZ_REMET=https://...       # URL da consulta como REMETENTE

# --- Google Sheets (fonte viva de empresas/credenciais) ---
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/.../edit
# No container o compose já aponta para /run/credentials/google-sa.json.
# Em desktop/WSL, descomente e ajuste:
# GOOGLE_CREDENTIALS_FILE=credentials/citric-nimbus-436114-g8-daacef9f0900.json

# --- CAPTCHA (Capsolver) ---
API_KEY=                      # chave do Capsolver

# --- Execução ---
DOWNLOAD_TIMEOUT=60           # segundos de espera por download
MAX_WORKERS=3                 # threads paralelas no batch

# --- Destino físico das planilhas ---
# Desktop Windows: R:\FISCAL\00 PLANILHA SEFAZ (default no código).
# Container: o compose seta DESTINO_BASE=/share/00 PLANILHA SEFAZ.
# DESTINO_BASE=

# Path do share no HOST (do lado do compose, não do container). Default cobre
# CIFS in-kernel em /mnt/fiscal. No SRVRPS03 (Windows + WSL2 + Docker) o share
# entra via drvfs em /mnt/r (R: do Windows). Ver compose para detalhes.
# SHARE_HOST_PATH=/mnt/fiscal      # Linux nativo + CIFS in-kernel
# SHARE_HOST_PATH=/mnt/r/FISCAL    # SRVRPS03 (Windows + WSL2 + drvfs)

# --- Chrome/ChromeDriver ---
# Container: o compose seta CHROMIUM. Desktop: deixe em branco (webdriver-manager).
# CHROME_BINARY=
# CHROMEDRIVER_PATH=
# HEADLESS=true                # sempre true em container

# --- rps-maestro (worker mode — FASE 4/5) ---
WORKER_ID=                            # default: worker-<hostname>
MAESTRO_API_URL=http://host.docker.internal:8080
MAESTRO_WORKER_API_KEY=               # X-Worker-API-Key (vazio = dev/sem auth)
MAESTRO_RABBITMQ_HOST=host.docker.internal
MAESTRO_RABBITMQ_PORT=5672
MAESTRO_RABBITMQ_USER=guest
MAESTRO_RABBITMQ_PASSWORD=guest
MAESTRO_RABBITMQ_QUEUE=bot-planilha-tasks

# --- Tuning ---
LOG_LEVEL=INFO
SHEET_CACHE_TTL_S=300         # TTL do cache do DataFrame da Sheet entre jobs
